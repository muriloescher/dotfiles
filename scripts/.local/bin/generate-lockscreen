#!/usr/bin/env bash
set -euo pipefail

SRC="$HOME/.local/share/wallpapers/current"
OUT="$HOME/.cache/lockscreen.png"

mkdir -p "$HOME/.cache"

if [[ ! -e "$SRC" ]]; then
  echo "Current wallpaper symlink not found: $SRC" >&2
  exit 1
fi

if command -v magick >/dev/null 2>&1; then
  IM=(magick)
elif command -v convert >/dev/null 2>&1; then
  IM=(convert)
else
  echo "Neither 'magick' nor 'convert' is installed" >&2
  exit 1
fi

read -r VIRT_W VIRT_H < <(
  xrandr | awk '/current/ {gsub(/,/, "", $10); print $8, $10}'
)

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

canvas="$tmpdir/canvas.png"
"${IM[@]}" -size "${VIRT_W}x${VIRT_H}" xc:black "$canvas"

idx=0
while read -r output geom; do
  IFS='x+' read -r W H X Y <<< "$geom"

  tile="$tmpdir/tile-$idx.png"
  composed="$tmpdir/composed-$idx.png"

  "${IM[@]}" "$SRC" \
    -resize "${W}x${H}^" \
    -gravity center \
    -extent "${W}x${H}" \
    "$tile"

  "${IM[@]}" "$canvas" "$tile" \
    -geometry "+${X}+${Y}" \
    -composite \
    "$composed"

  mv "$composed" "$canvas"
  idx=$((idx + 1))
done < <(
  xrandr | awk '
    / connected/ && $0 !~ /disconnected/ {
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^[0-9]+x[0-9]+\+[0-9]+\+[0-9]+$/) {
          print $1, $i
          break
        }
      }
    }
  '
)

mv "$canvas" "$OUT"
printf '%s\n' "$OUT"
