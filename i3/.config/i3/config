client.focused          #cba6f7   #11111b     #e6e9ef   #cba6f7     #cba6f7
client.focused_inactive #313244   #11111b     #cdd6f4   #313244     #313244
client.unfocused        #181825   #11111b     #a6adc8   #181825     #181825
client.urgent           #f38ba8   #f38ba8     #11111b   #f38ba8     #f38ba8
client.placeholder      #181825   #181825     #cdd6f4   #181825     #181825

client.background       #11111b
